{
  "scriptId": "<YOUR_SCRIPT_ID>",
  "rootDir": ".",
  "scriptExtensions": [".gs"],
  "htmlExtensions": [".html"],
  "jsonExtensions": [".json"],
  "filePushOrder": [
    "src/config/sheet.schema.gs",
    "src/config/app.config.gs",
    "src/shared/utils.gs",
    "src/shared/logger.gs",
    "src/shared/response.factory.gs",
    "src/domain/task.mapper.gs",
    "src/domain/task.sorter.gs",
    "src/domain/backlog.formatter.gs",
    "src/domain/daily-report.builder.gs",
    "src/domain/daily-report-message.builder.gs",
    "src/repositories/spreadsheet.repository.gs",
    "src/repositories/backlog.repository.gs",
    "src/repositories/daily-report.repository.gs",
    "src/repositories/script-properties.repository.gs",
    "src/repositories/lock.repository.gs",
    "src/repositories/execution-state.repository.gs",
    "src/services/backlog.service.gs",
    "src/services/daily-report.service.gs",
    "src/services/refresh.service.gs",
    "src/services/execution-coordinator.service.gs",
    "src/api/auth.gs",
    "src/api/tasks.gs",
    "src/api/reports.gs",
    "src/api/router.gs",
    "src/app/desktop.entry.gs",
    "src/app/api.entry.gs",
    "src/app/main.gs"
  ],
  "skipSubdirectories": false
}
